tarefas = []
    
while True:
    print("\n--- MENU ---")
    print(" 1 -Adicionar Tarefas")
    print(" 2 -Listar Tarefas")
    print(" 3 -Remover Tarefas")
    print(" 4 -Sair")

    escolha = input("Escolha: ")

    if escolha == "1":
        tarefa = input("insira a tarefa: ")
        tarefas.append(tarefa)

    elif escolha == "2":
        for i, tarefa in enumerate(tarefas):
            print(f"{i} - {tarefa}")
    
    elif escolha == "3":
        try:
             indice = int(input("insira o indice: "))
             tarefas.pop(indice)
        except ValueError:
            print("Erro: Indice invalido.")
        except IndexError:
            print("Erro: Índice não existe.")

    elif escolha == "4":
        print("tarefas finalizadas.")
        break
    
